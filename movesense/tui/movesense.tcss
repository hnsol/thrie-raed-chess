Screen {
    background: $surface;
}

#menu-body,
#puzzle-select-body,
#puzzle-difficulty-body,
#puzzle-number-info {
    padding: 2 4;
}

#board-row {
    height: 1fr;
}

#board {
    width: auto;
    height: auto;
}

#side {
    width: 34;
    height: 1fr;
    border: solid $primary;
    padding: 0 1;
}

#panel-header {
    height: 1;
    text-style: bold;
}

#movelog,
#stats-body,
#guide-body {
    height: 1fr;
}
